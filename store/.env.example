# PlugICT license-webhook environment — copy to .env for local runs, or paste
# these into your host's dashboard (Render reads them from render.yaml prompts).
# NEVER commit the filled-in version. Details: store/DEPLOY.md.

# ── Signature verification ───────────────────────────────────────────────
# Stripe's *signing secret* from the webhook endpoint (Dashboard > Developers >
# Webhooks > your endpoint > Signing secret). NOT your API key.
# Leave empty ONLY for local testing — an empty secret accepts every request.
WEBHOOK_SECRET=whsec_xxx
# Optional: reject Stripe events whose timestamp is older than N seconds.
# Unset/0 disables it (safe — idempotency already blocks replays).
STRIPE_SIG_TOLERANCE=300

# ── Email delivery via Resend over SMTP (free tier) ──────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxx          # your Resend API key
SMTP_FROM=licenses@yourdomain  # a sender you verified in Resend

# ── Buyer-facing URLs put into the license email ─────────────────────────
ICT_VAULT_DOWNLOAD_URL=https://github.com/godzillacode0000/plugICT/releases/latest
ICT_GETTING_STARTED_URL=https://godzillacode0000.github.io/plugICT/#setup
ICT_SUPPORT_EMAIL=hermesian0000@gmail.com

# Blind-copy every issued license to yourself, so you keep a durable record of
# all sales even though Render's ledger CSV lives on ephemeral disk. Defaults to
# ICT_SUPPORT_EMAIL if unset; set a different address here, or "off" to disable.
# LICENSE_BCC=hermesian0000@gmail.com

# ── Seller secret location ───────────────────────────────────────────────
# Directory holding .vault_key + .vault_sha256 (the master key that mints
# licenses). On Render, upload them as Secret Files into /etc/secrets.
# Locally, point this at your scripts/ dir after `python scripts/build.py`.
ICT_SOURCE_DIR=/etc/secrets
